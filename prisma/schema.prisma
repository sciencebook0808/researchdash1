// prisma/schema.prisma
// Prisma ORM v7 — url/directUrl moved to prisma.config.ts
//
// IMPORTANT: provider = "prisma-client-js" is intentional even on Prisma v7.
// The newer "prisma-client" provider causes Turbopack module resolution failures
// in Next.js 16. Using "prisma-client-js" generates the identical client with a
// file structure that Turbopack resolves correctly at build time.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------
// USERS & ROLES
// ---------------------------------------------

enum UserRole {
  super_admin
  admin
  developer
  user
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  email     String    @unique
  name      String?
  imageUrl  String?
  role      UserRole  @default(user)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[] @relation("ProjectCreator")

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

// ---------------------------------------------
// PROJECTS
// ---------------------------------------------

enum ProjectType {
  MODEL
  FRONTEND
  BACKEND
  CUSTOM
}

model Project {
  id            String      @id @default(cuid())
  name          String
  type          ProjectType
  description   String?
  config        Json?
  createdById   String
  createdByName String?
  createdBy     User        @relation("ProjectCreator", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  datasets      Dataset[]
  experiments   Experiment[]
  documentation DocumentationPage[]
  roadmapSteps  RoadmapStep[]
  notes         Note[]
  modelVersions ModelVersion[]
  chatSessions  ChatSession[]

  @@index([createdById])
  @@index([type])
  @@index([name])
}

// ---------------------------------------------
// ROADMAP
// ---------------------------------------------

model RoadmapStep {
  id                  String       @id @default(cuid())
  phase               Int
  title               String
  description         String
  status              StepStatus   @default(PENDING)
  order               Int          @default(0)
  priority            String?
  milestone           String?
  estimatedCompletion DateTime?
  progressPercent     Int          @default(0)
  tasks               RoadmapTask[]
  projectId           String?
  project             Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phase])
  @@index([status])
  @@index([projectId])
}

model RoadmapTask {
  id        String      @id @default(cuid())
  title     String
  completed Boolean     @default(false)
  stepId    String
  step      RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([stepId])
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ---------------------------------------------
// DOCUMENTATION
// ---------------------------------------------

model DocumentationPage {
  id        String      @id @default(cuid())
  title     String
  slug      String      @unique
  content   String
  section   String
  order     Int         @default(0)
  tags      String[]
  progress  DocProgress @default(NOT_STARTED)
  versions  DocVersion[]
  projectId String?
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section])
  @@index([slug])
  @@index([projectId])
}

enum DocProgress {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model DocVersion {
  id        String            @id @default(cuid())
  content   String
  version   Int
  pageId    String
  page      DocumentationPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@index([pageId])
}

// ---------------------------------------------
// DATASETS
// ---------------------------------------------

model Dataset {
  id               String        @id @default(cuid())
  name             String
  description      String?
  sourceUrl        String?
  datasetType      DatasetType
  numSamples       Int?
  sizeBytes        BigInt?
  preprocessStatus PreprocStatus @default(RAW)
  tags             String[]
  format           String?
  license          String?
  experiments      Experiment[]
  projectId        String?
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([datasetType])
  @@index([preprocessStatus])
  @@index([projectId])
}

enum DatasetType {
  CODE
  TEXT
  INSTRUCTION
  QA
  MIXED
}

enum PreprocStatus {
  RAW
  CLEANING
  CLEANED
  FORMATTED
  AUGMENTED
  READY
}

// ---------------------------------------------
// EXPERIMENTS
// ---------------------------------------------

model Experiment {
  id            String           @id @default(cuid())
  name          String
  description   String?
  baseModel     String
  datasetId     String?
  dataset       Dataset?         @relation(fields: [datasetId], references: [id])
  status        ExperimentStatus @default(PENDING)
  method        String?
  resultSummary String?
  config        Json?
  loraRank      Int?
  loraAlpha     Int?
  batchSize     Int?
  learningRate  Float?
  epochs        Int?
  evalLoss      Float?
  evalAccuracy  Float?
  bleuScore     Float?
  pass1Score    Float?
  logs          ExperimentLog[]
  modelVersions ModelVersion[]
  projectId     String?
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([datasetId])
  @@index([projectId])
}

model ExperimentLog {
  id           String     @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  step         Int
  loss         Float?
  learningRate Float?
  message      String?
  createdAt    DateTime   @default(now())

  @@index([experimentId])
}

enum ExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ---------------------------------------------
// MODEL VERSIONS
// ---------------------------------------------

model ModelVersion {
  id               String            @id @default(cuid())
  name             String
  version          String
  description      String?
  parameterCount   BigInt?
  experimentId     String?
  experiment       Experiment?       @relation(fields: [experimentId], references: [id])
  quantization     QuantizationType?
  deploymentFormat String?
  bleuScore        Float?
  pass1Score       Float?
  humanEval        Float?
  mmluScore        Float?
  fileSizeBytes    BigInt?
  isDeployed       Boolean           @default(false)
  notes            String?
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
  @@index([experimentId])
  @@index([projectId])
}

enum QuantizationType {
  NONE
  INT8
  INT4
  GPTQ
  GGUF
  AWQ
}

// ---------------------------------------------
// AI SETTINGS
// ---------------------------------------------

model AISettings {
  id                       String   @id @default(cuid())
  defaultProvider          String   @default("gemini")
  geminiApiKey             String?
  geminiDefaultModel       String   @default("gemini-2.5-flash")
  openrouterApiKey         String?
  selectedOpenRouterModels String[] @default([])
  updatedBy                String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tavilyApiKey           String?
  exaApiKey              String?
  serpApiKey             String?
  firecrawlApiKey        String?
  crawl4aiUrl            String?
  imageGenerationModel   String?  @default("auto")
  cloudinaryCloudName    String?
  cloudinaryUploadPreset String?
  cloudinaryApiKey       String?
}

// ---------------------------------------------
// NOTES
// ---------------------------------------------

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[]
  pinned    Boolean  @default(false)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdByUserId      String?
  createdByUserName    String?
  createdWithAIModel   String?
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned])
  @@index([projectId])
}

// ---------------------------------------------
// CHAT SESSIONS
// ---------------------------------------------

enum ChatVisibility {
  team
  private
}

model ChatSession {
  id          String         @id @default(cuid())
  title       String         @default("New Chat")
  creatorId   String
  creatorName String?
  visibility  ChatVisibility @default(team)
  messages    ChatMessage[]
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([creatorId])
  @@index([visibility])
  @@index([updatedAt])
  @@index([projectId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// ---------------------------------------------
// AGENT FILES
// ---------------------------------------------

enum AgentFileType {
  system
  rules
  tools
}

model AgentFile {
  id        String           @id @default(cuid())
  name      String
  type      AgentFileType    @default(rules)
  content   String
  isActive  Boolean          @default(true)
  order     Int              @default(0)
  history   AgentFileHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([order])
}

model AgentFileHistory {
  id        String    @id @default(cuid())
  fileId    String
  file      AgentFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content   String
  version   Int
  savedBy   String?
  createdAt DateTime  @default(now())

  @@index([fileId])
  @@index([createdAt])
}

// ---------------------------------------------
// AGENT JOBS — Background job checkpointing
// ---------------------------------------------

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
}

/// Tracks a single agent invocation (one user message → agent response).
/// Created when POST /api/agent is called; updated as events stream in.
model AgentJob {
  id           String          @id @default(cuid())
  sessionId    String
  status       JobStatus       @default(RUNNING)
  /// Accumulated final assistant text (updated as text deltas arrive)
  finalContent String?
  error        String?
  provider     String          @default("gemini")
  modelId      String          @default("gemini-2.5-flash")
  events       AgentJobEvent[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([updatedAt])
}

/// One row per SSE event emitted by the agent.
/// Allows clients to replay the exact event stream after reconnecting.
model AgentJobEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sequence  Int
  eventType String
  /// Full JSON payload sent over SSE
  data      Json
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([jobId, sequence])
}

// ---------------------------------------------
// CHAT ATTACHMENTS — Files uploaded in chat
// ---------------------------------------------

/// A file attached to a chat message.
/// Stores the Cloudinary URL + optionally extracted text content.
model ChatAttachment {
  id        String   @id @default(cuid())
  sessionId String
  /// Null until the message is persisted
  messageId String?
  name      String
  mimeType  String
  size      Int      @default(0)
  /// Cloudinary CDN URL
  url       String
  /// Extracted text: DOCX → plain text, CSV → JSON string, PDF → null (model reads URL)
  content   String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([messageId])
}
