// prisma/schema.prisma
// Prisma ORM v7 — url/directUrl moved to prisma.config.ts (not allowed in schema)
// Generator uses "prisma-client" with explicit output path (required in v7)
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS & ROLES
// ─────────────────────────────────────────────

enum UserRole {
  super_admin
  admin
  developer
  user
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  role      UserRole @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[] @relation("ProjectCreator")

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

enum ProjectType {
  MODEL
  FRONTEND
  BACKEND
  CUSTOM
}

model Project {
  id            String      @id @default(cuid())
  name          String
  type          ProjectType
  description   String?     @db.Text
  config        Json?       // Stores type-specific config (modelType, platform, frameworks, etc.)
  createdById   String
  createdByName String?
  createdBy     User        @relation("ProjectCreator", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations to project-scoped entities
  datasets       Dataset[]
  experiments    Experiment[]
  documentation  DocumentationPage[]
  roadmapSteps   RoadmapStep[]
  notes          Note[]
  modelVersions  ModelVersion[]
  chatSessions   ChatSession[]

  @@index([createdById])
  @@index([type])
  @@index([name])
}

// ─────────────────────────────────────────────
// ROADMAP
// ─────────────────────────────────────────────

model RoadmapStep {
  id                  String      @id @default(cuid())
  phase               Int
  title               String
  description         String      @db.Text
  status              StepStatus  @default(PENDING)
  order               Int         @default(0)
  priority            String?
  milestone           String?
  estimatedCompletion DateTime?
  progressPercent     Int         @default(0)
  tasks               RoadmapTask[]
  projectId           String?
  project             Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([phase])
  @@index([status])
  @@index([projectId])
}

model RoadmapTask {
  id        String      @id @default(cuid())
  title     String
  completed Boolean     @default(false)
  stepId    String
  step      RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([stepId])
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─────────────────────────────────────────────
// DOCUMENTATION
// ─────────────────────────────────────────────

model DocumentationPage {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String       @db.Text
  section     String
  order       Int          @default(0)
  tags        String[]
  progress    DocProgress  @default(NOT_STARTED)
  versions    DocVersion[]
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([section])
  @@index([slug])
  @@index([projectId])
}

enum DocProgress {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model DocVersion {
  id        String            @id @default(cuid())
  content   String            @db.Text
  version   Int
  pageId    String
  page      DocumentationPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@index([pageId])
}

// ─────────────────────────────────────────────
// DATASETS
// ─────────────────────────────────────────────

model Dataset {
  id               String        @id @default(cuid())
  name             String
  description      String?       @db.Text
  sourceUrl        String?
  datasetType      DatasetType
  numSamples       Int?
  sizeBytes        BigInt?
  preprocessStatus PreprocStatus @default(RAW)
  tags             String[]
  format           String?
  license          String?
  experiments      Experiment[]
  projectId        String?
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([datasetType])
  @@index([preprocessStatus])
  @@index([projectId])
}

enum DatasetType {
  CODE
  TEXT
  INSTRUCTION
  QA
  MIXED
}

enum PreprocStatus {
  RAW
  CLEANING
  CLEANED
  FORMATTED
  AUGMENTED
  READY
}

// ─────────────────────────────────────────────
// EXPERIMENTS
// ─────────────────────────────────────────────

model Experiment {
  id            String           @id @default(cuid())
  name          String
  description   String?          @db.Text
  baseModel     String
  datasetId     String?
  dataset       Dataset?         @relation(fields: [datasetId], references: [id])
  status        ExperimentStatus @default(PENDING)
  method        String?
  resultSummary String?          @db.Text
  config        Json?
  loraRank      Int?
  loraAlpha     Int?
  batchSize     Int?
  learningRate  Float?
  epochs        Int?
  evalLoss      Float?
  evalAccuracy  Float?
  bleuScore     Float?
  pass1Score    Float?
  logs          ExperimentLog[]
  modelVersions ModelVersion[]
  projectId     String?
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([datasetId])
  @@index([projectId])
}

model ExperimentLog {
  id           String     @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  step         Int
  loss         Float?
  learningRate Float?
  message      String?
  createdAt    DateTime   @default(now())

  @@index([experimentId])
}

enum ExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─────────────────────────────────────────────
// MODEL VERSIONS
// ─────────────────────────────────────────────

model ModelVersion {
  id               String            @id @default(cuid())
  name             String
  version          String
  description      String?           @db.Text
  parameterCount   BigInt?
  experimentId     String?
  experiment       Experiment?       @relation(fields: [experimentId], references: [id])
  quantization     QuantizationType?
  deploymentFormat String?
  bleuScore        Float?
  pass1Score       Float?
  humanEval        Float?
  mmluScore        Float?
  fileSizeBytes    BigInt?
  isDeployed       Boolean           @default(false)
  notes            String?           @db.Text
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([version])
  @@index([experimentId])
  @@index([projectId])
}

enum QuantizationType {
  NONE
  INT8
  INT4
  GPTQ
  GGUF
  AWQ
}

// ─────────────────────────────────────────────
// AI SETTINGS
// ─────────────────────────────────────────────

model AISettings {
  id                       String   @id @default(cuid())
  defaultProvider          String   @default("gemini")
  geminiApiKey             String?  @db.Text
  geminiDefaultModel       String   @default("gemini-2.5-flash")
  openrouterApiKey         String?  @db.Text
  selectedOpenRouterModels String[] @default([])
  updatedBy                String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  tags      String[]
  pinned    Boolean  @default(false)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Author tracking
  createdByUserId     String?
  createdByUserName   String?
  
  // Edit attribution
  lastEditedByUserId   String?
  lastEditedByUserName String?
  lastEditedAt         DateTime?
  editedWithAIModel    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned])
  @@index([projectId])
}

// ─────────────────────────────────────────────
// CHAT SESSIONS
// ─────────────────────────────────────────────

enum ChatVisibility {
  team
  private
}

model ChatSession {
  id          String         @id @default(cuid())
  title       String         @default("New Chat")
  creatorId   String
  creatorName String?
  visibility  ChatVisibility @default(team)
  messages    ChatMessage[]
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([creatorId])
  @@index([visibility])
  @@index([updatedAt])
  @@index([projectId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String      @db.Text
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}
